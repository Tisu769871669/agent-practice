---
import type { Challenge } from "../lib/challenges";
import { localizedPath, type Locale } from "../lib/i18n";

const {
  challenge,
  lang = "en",
  runCommand,
} = Astro.props as {
  challenge: Challenge;
  lang?: Locale;
  runCommand: string;
};

const copy = lang === "zh"
  ? {
      practiceSignal: "练习信号",
      fallbackText: "在本地完成这道题，查看评分报告，然后逐步收紧智能体行为，直到它满足挑战契约。",
      background: "题目背景",
      objective: "任务目标",
      input: "输入格式",
      output: "输出格式",
      scoring: "评分标准",
      scoringStandard: "APS-1 判题标准",
      acceptedRule: "通过定义",
      acceptedText: "只有结构、运行、安全和分数门禁全部通过，才会得到 accepted。",
      gatesTitle: "门禁",
      verdictsTitle: "结果类型",
      readPolicy: "查看完整评分标准",
      examples: "样例",
      exampleInput: "样例输入",
      exampleOutput: "样例输出",
      pitfalls: "常见坑",
      stretch: "进阶挑战",
      runner: "本地 Runner",
    }
  : {
      practiceSignal: "Practice Signal",
      fallbackText:
        "Solve this locally, inspect the grader report, then tighten the agent behavior until it satisfies the challenge contract.",
      background: "Background",
      objective: "Objective",
      input: "Input Contract",
      output: "Output Contract",
      scoring: "Scoring",
      scoringStandard: "APS-1 Grading Standard",
      acceptedRule: "Accepted Rule",
      acceptedText:
        "A run is accepted only when structure, runtime, safety, and score gates all pass.",
      gatesTitle: "Gates",
      verdictsTitle: "Verdicts",
      readPolicy: "Read full grading policy",
      examples: "Examples",
      exampleInput: "Example Input",
      exampleOutput: "Example Output",
      pitfalls: "Common Pitfalls",
      stretch: "Stretch Goal",
      runner: "Local Runner",
    };

const detail = challenge.detail;
const formatJson = (value: Record<string, unknown>) => JSON.stringify(value, null, 2);
const gateItems = lang === "zh"
  ? [
      "schema_validity: 输出符合声明的 JSON schema 或结构化契约。",
      "no_runtime_error: 提交运行时没有崩溃。",
      "no_timeout: 每个用例都在时间限制内完成。",
      "no_safety_violation: 安全和提示注入检查没有失败。",
      "score_threshold: 总分达到本题通过线。",
    ]
  : [
      "schema_validity: outputs satisfy the declared JSON schema or structured contract.",
      "no_runtime_error: the submission does not crash during execution.",
      "no_timeout: every case finishes within the runtime limit.",
      "no_safety_violation: safety and prompt-injection checks pass.",
      "score_threshold: total score reaches the challenge pass threshold.",
    ];
const verdictItems = lang === "zh"
  ? [
      ["accepted", "通过"],
      ["wrong_answer", "答案错误"],
      ["partial_pass", "部分得分"],
      ["schema_error", "结构错误"],
      ["runtime_error", "运行错误"],
      ["timeout", "超时"],
      ["safety_violation", "安全违规"],
    ]
  : [
      ["accepted", "accepted"],
      ["wrong_answer", "wrong answer"],
      ["partial_pass", "partial pass"],
      ["schema_error", "schema error"],
      ["runtime_error", "runtime error"],
      ["timeout", "timeout"],
      ["safety_violation", "safety violation"],
    ];
---

{detail ? (
  <>
    <section class="section detail-grid">
      <article class="detail-block">
        <div class="section-kicker">{copy.background}</div>
        <p>{detail.background}</p>
      </article>
      <article class="detail-block">
        <div class="section-kicker">{copy.objective}</div>
        <p>{detail.objective}</p>
      </article>
    </section>

    <section class="section detail-section-grid">
      <article class="detail-block">
        <div class="section-kicker">{copy.input}</div>
        <p>{detail.input_contract}</p>
      </article>
      <article class="detail-block">
        <div class="section-kicker">{copy.output}</div>
        <p>{detail.output_contract}</p>
      </article>
      <article class="detail-block">
        <div class="section-kicker">{copy.scoring}</div>
        <p>{detail.scoring}</p>
      </article>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="section-kicker">{copy.examples}</div>
          <h2>{challenge.title}</h2>
        </div>
      </div>
      <div class="example-grid">
        <article class="detail-block">
          <h3>{copy.exampleInput}</h3>
          <pre><code>{formatJson(detail.example_input)}</code></pre>
        </article>
        <article class="detail-block">
          <h3>{copy.exampleOutput}</h3>
          <pre><code>{formatJson(detail.example_output)}</code></pre>
        </article>
      </div>
    </section>

    <section class="section detail-grid">
      <article class="detail-block">
        <div class="section-kicker">{copy.pitfalls}</div>
        <ul class="pitfall-list">
          {detail.common_pitfalls.map((pitfall) => <li>{pitfall}</li>)}
        </ul>
      </article>
      <article class="detail-block">
        <div class="section-kicker">{copy.stretch}</div>
        <p>{detail.stretch_goal}</p>
      </article>
    </section>

    <section class="section">
      <article class="detail-block">
        <div class="section-kicker">{copy.runner}</div>
        <pre><code>{runCommand}</code></pre>
      </article>
    </section>
  </>
) : (
  <section class="section detail-grid">
    <article class="detail-block">
      <div class="section-kicker">{copy.practiceSignal}</div>
      <h3>{challenge.focus}</h3>
      <p>{copy.fallbackText}</p>
    </article>
    <article class="detail-block">
      <div class="section-kicker">{copy.runner}</div>
      <pre><code>{runCommand}</code></pre>
    </article>
  </section>
)}

<section class="section aps-section">
  <div class="section-head">
    <div>
      <div class="section-kicker">APS-1</div>
      <h2>{copy.scoringStandard}</h2>
    </div>
    <a class="ghost-button" href={localizedPath("/scoring", lang)}>{copy.readPolicy}</a>
  </div>
  <div class="grading-grid">
    <article class="detail-block scoring-rule">
      <div class="section-kicker">{copy.acceptedRule}</div>
      <code>accepted = all gates pass + score threshold met</code>
      <p>{copy.acceptedText}</p>
    </article>
    <article class="detail-block">
      <div class="section-kicker">{copy.gatesTitle}</div>
      <ul class="gate-list">
        {gateItems.map((gate) => <li>{gate}</li>)}
      </ul>
    </article>
  </div>
  <div class="section-kicker verdict-heading">{copy.verdictsTitle}</div>
  <div class="verdict-grid">
    {verdictItems.map(([name, label]) => (
      <article class="verdict-chip">
        <strong>{name}</strong>
        <span>{label}</span>
      </article>
    ))}
  </div>
</section>
