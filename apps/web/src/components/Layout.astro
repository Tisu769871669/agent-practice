---
import "../styles/global.css";
import {
  layoutCopy,
  localeMeta,
  localizedPath,
  oppositeLocale,
  type Locale,
} from "../lib/i18n";

const {
  title = "Agent Practice",
  lang = "en",
  canonicalPath = "/",
} = Astro.props as {
  title?: string;
  description?: string;
  lang?: Locale;
  canonicalPath?: string;
};
const locale = lang;
const copy = layoutCopy[locale];
const description = Astro.props.description ?? copy.defaultDescription;
const alternateLocale = oppositeLocale(locale);
---

<!doctype html>
<html lang={localeMeta[locale].htmlLang} class={`locale-${locale}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a href={localizedPath("/", locale)} class="brand">
          <span class="brand-mark">AP</span>
          <span class="brand-copy">
            <strong>Agent Practice</strong>
            <small>{copy.tagline}</small>
          </span>
        </a>
        <nav class="nav">
          <a href={localizedPath("/path", locale)}>{copy.nav.path}</a>
          <a href={localizedPath("/challenges", locale)}>{copy.nav.challenges}</a>
          <a href={localizedPath("/scoring", locale)}>{copy.nav.scoring}</a>
          <a href={localizedPath("/contribute", locale)}>{copy.nav.contribute}</a>
          <a
            href="https://github.com/Tisu769871669/agent-practice"
            target="_blank"
            rel="noreferrer"
          >
            {copy.nav.github}
          </a>
          <a class="language-toggle" href={localizedPath(canonicalPath, alternateLocale)}>
            {copy.switchLanguage}
          </a>
        </nav>
      </header>
      <main class="page">
        <slot />
      </main>
    </div>
  </body>
</html>
