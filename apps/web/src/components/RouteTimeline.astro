---
import type { Stage } from "../lib/challenges";

const { stages } = Astro.props as { stages: Stage[] };
---

<section class="timeline">
  {stages.map((stage, index) => (
    <div class="timeline-item">
      <div class="timeline-index">{String(index + 1).padStart(2, "0")}</div>
      <div>
        <h3>{stage.name}</h3>
        <p>{stage.note}</p>
        <div class="timeline-metrics">
          <span>{stage.total} tasks</span>
          <span>{stage.runnable} live</span>
        </div>
      </div>
    </div>
  ))}
</section>
