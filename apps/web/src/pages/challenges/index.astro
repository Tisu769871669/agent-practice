---
import Layout from "../../components/Layout.astro";
import { challenges } from "../../lib/challenges";
---

<Layout title="Agent Practice | Challenge Catalog">
  <section class="page-hero">
    <div class="copy-block">
      <div class="section-kicker">Catalog</div>
      <h2>Scan by skill, not by marketing copy.</h2>
      <p>
        The catalog is biased toward what an engineer actually needs while learning agents: task shape, difficulty,
        stage, runnable status, and the thing you are supposed to get better at.
      </p>
    </div>
    <div class="copy-block">
      <div class="section-kicker">Launch Filters</div>
      <div class="chip-row">
        <span class="tag">easy</span>
        <span class="tag">medium</span>
        <span class="tag">hard</span>
        <span class="tag">expert</span>
        <span class="tag">runnable</span>
        <span class="tag">planned</span>
      </div>
      <p class="footer-note">Dynamic filters can come later; for now this page is the stable source of challenge visibility.</p>
    </div>
  </section>

  <section class="section">
    <div class="list-table">
      {challenges.map((challenge) => (
        <div class="list-row">
          <span class="mono">{challenge.id}</span>
          <div>
            <strong>{challenge.title}</strong>
            <span class="muted">{challenge.focus}</span>
          </div>
          <span>{challenge.stage}</span>
          <span>{challenge.est}</span>
          <span class={`status ${challenge.status}`}>{challenge.status}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
