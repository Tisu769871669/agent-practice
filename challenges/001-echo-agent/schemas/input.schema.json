{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Echo Agent Input",
  "type": "object",
  "required": ["message", "facts"],
  "additionalProperties": false,
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
