{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Echo Agent Output",
  "type": "object",
  "required": ["facts", "added_facts"],
  "additionalProperties": false,
  "properties": {
    "facts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "added_facts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
