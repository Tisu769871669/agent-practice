{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Picker Input",
  "type": "object",
  "required": ["request", "available_tools"],
  "additionalProperties": false,
  "properties": {
    "request": {
      "type": "string",
      "minLength": 1
    },
    "available_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "arguments"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "arguments": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
