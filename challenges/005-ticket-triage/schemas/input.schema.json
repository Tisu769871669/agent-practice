{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ticket Triage Input",
  "type": "object",
  "required": ["ticket"],
  "additionalProperties": false,
  "properties": {
    "ticket": {
      "type": "object",
      "required": ["subject", "body"],
      "additionalProperties": false,
      "properties": {
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
