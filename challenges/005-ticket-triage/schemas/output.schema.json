{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ticket Triage Output",
  "type": "object",
  "required": ["category", "severity"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "enum": ["account", "billing", "bug", "feature", "security"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    }
  }
}
