{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mini RAG Input",
  "type": "object",
  "required": ["question", "docs"],
  "additionalProperties": false,
  "properties": {
    "question": {
      "type": "string",
      "minLength": 1
    },
    "docs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "text"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
