{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Error Recovery Input",
  "type": "object",
  "required": ["goal", "attempts"],
  "additionalProperties": false,
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tool", "status"],
        "additionalProperties": false,
        "properties": {
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "result": {},
          "error_code": {
            "type": "string",
            "minLength": 1
          },
          "error_message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
