{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Error Recovery Output",
  "type": "object",
  "required": ["final_status", "action"],
  "additionalProperties": false,
  "properties": {
    "final_status": {
      "type": "string",
      "enum": ["recovered", "needs_retry", "needs_user", "failed"]
    },
    "action": {
      "type": "string",
      "minLength": 1
    }
  }
}
