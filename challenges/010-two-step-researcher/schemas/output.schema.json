{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Two-Step Researcher Output",
  "type": "object",
  "required": ["steps", "answer", "citations"],
  "additionalProperties": false,
  "properties": {
    "steps": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["retrieve", "answer"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
