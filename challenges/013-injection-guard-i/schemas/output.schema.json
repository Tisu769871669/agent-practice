{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Injection Guard I Output",
  "type": "object",
  "required": ["answer", "citations", "ignored_instructions"],
  "additionalProperties": false,
  "properties": {
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ignored_instructions": {
      "type": "boolean"
    }
  }
}
