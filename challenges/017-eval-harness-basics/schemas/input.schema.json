{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eval Harness Basics Input",
  "type": "object",
  "required": ["candidate_output", "expected", "rubric"],
  "additionalProperties": false,
  "properties": {
    "candidate_output": {
      "type": "object"
    },
    "expected": {
      "type": "object"
    },
    "rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
