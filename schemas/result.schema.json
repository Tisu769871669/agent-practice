{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-practice.dev/schemas/result.schema.json",
  "title": "Agent Practice Result",
  "type": "object",
  "required": [
    "schema_version",
    "challenge_id",
    "challenge_version",
    "runner_version",
    "submission_id",
    "template",
    "score",
    "max_score",
    "passed",
    "verdict",
    "gates",
    "failure_reasons",
    "duration_ms",
    "metrics",
    "cases",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "challenge_id": {
      "type": "string",
      "minLength": 1
    },
    "challenge_version": {
      "type": "string",
      "minLength": 1
    },
    "runner_version": {
      "type": "string",
      "minLength": 1
    },
    "submission_id": {
      "type": "string",
      "minLength": 1
    },
    "template": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number",
      "minimum": 0
    },
    "max_score": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "passed": {
      "type": "boolean"
    },
    "verdict": {
      "$ref": "#/$defs/verdict"
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "failure_reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure_reason"
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/case"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "verdict": {
      "type": "string",
      "enum": [
        "accepted",
        "wrong_answer",
        "schema_error",
        "timeout",
        "runtime_error",
        "safety_violation",
        "partial_pass"
      ]
    },
    "failure_reason": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": ["name", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "message": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "metric": {
      "type": "object",
      "required": ["name", "score", "max_score", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": 0
        },
        "max_score": {
          "type": "number",
          "minimum": 0
        },
        "passed": {
          "type": "boolean"
        },
        "feedback": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "case": {
      "type": "object",
      "required": [
        "case_id",
        "score",
        "max_score",
        "passed",
        "duration_ms",
        "verdict",
        "failure_reasons"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": 0
        },
        "max_score": {
          "type": "number",
          "minimum": 0
        },
        "passed": {
          "type": "boolean"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "failure_reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure_reason"
          }
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
